{
  "name": "@ohmyperf/website",
  "version": "0.0.0-pre",
  "private": true,
  "type": "module",
  "description": "ohmyperf.dev landing, measurement SPA, drag-drop viewer, hosted share UI.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true next build",
    "analyze:check": "ANALYZE=true next build && node scripts/check-bundle-budget.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "next lint --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:smoke": "playwright test",
    "clean": "rimraf .next out .turbo *.tsbuildinfo node_modules/.cache"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@ohmyperf/core": "workspace:*",
    "@ohmyperf/shared-types": "workspace:*",
    "@ohmyperf/viewer": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "idb": "catalog:",
    "lucide-react": "0.469.0",
    "next": "15.1.4",
    "next-intl": "3.26.3",
    "next-themes": "0.4.4",
    "radix-ui": "^1.4.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.54.2",
    "recharts": "catalog:",
    "sonner": "1.7.2",
    "tailwind-merge": "2.6.0",
    "uplot": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@next/bundle-analyzer": "15.1.4",
    "@playwright/test": "catalog:",
    "@tailwindcss/postcss": "4.0.0-beta.8",
    "@types/node": "^22.10.5",
    "@types/react": "19.0.4",
    "@types/react-dom": "19.0.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.4",
    "postcss": "8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "4.0.0-beta.8",
    "typescript": "^5.7.3",
    "vitest": "catalog:"
  }
}
