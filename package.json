{
  "name": "ohmyperf",
  "version": "0.1.0",
  "description": "Real-machine, real-browser web performance measurement platform with ~99% iframe coverage via CDP OOPIF deep-inspection.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/hoainho/ohmyperf#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoainho/ohmyperf.git"
  },
  "bugs": {
    "url": "https://github.com/ohmyperf/ohmyperf/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.3",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:oopif-corpus": "turbo run test:oopif-corpus",
    "test:parity": "turbo run test:parity",
    "test:visual": "turbo run test:visual --filter @ohmyperf/tests-visual-regression",
    "license:audit": "node scripts/license-audit.mjs",
    "check:design-tokens": "node scripts/check-design-tokens.mjs",
    "check:brand-licenses": "node scripts/check-brand-licenses.mjs",
    "sync:open-design": "node packages/design-tokens/scripts/sync-open-design.mjs --all",
    "api:check": "turbo run api:check",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.18.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "lighthouse": "^13.3.0"
  },
  "private": true,
  "author": "Hoài Nhớ <nhoxtvt@gmail.com>",
  "keywords": [
    "performance",
    "web-performance",
    "core-web-vitals",
    "cwv",
    "lcp",
    "inp",
    "cls",
    "lighthouse-alternative",
    "playwright",
    "chrome-devtools-protocol",
    "cdp",
    "oopif",
    "perf-measurement"
  ]
}
