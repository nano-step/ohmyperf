{
  "name": "@ohmyperf/eslint-plugin",
  "version": "0.1.0",
  "description": "ESLint rules that flag client-side performance anti-patterns linked to Core Web Vitals (LCP, INP, CLS, TBT). Shift-left companion to @ohmyperf/cli.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.0",
    "eslint": "^9.0.0",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoainho/ohmyperf.git",
    "directory": "packages/eslint-plugin"
  },
  "author": "Hoài Nhớ <nhoxtvt@gmail.com>",
  "homepage": "https://github.com/hoainho/ohmyperf#readme",
  "bugs": {
    "url": "https://github.com/hoainho/ohmyperf/issues"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "performance",
    "core-web-vitals",
    "lcp",
    "inp",
    "cls",
    "tbt",
    "ohmyperf"
  ]
}
