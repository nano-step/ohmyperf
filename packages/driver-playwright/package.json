{
  "name": "@ohmyperf/driver-playwright",
  "version": "0.0.0-pre",
  "description": "Playwright Driver implementation. Wraps newCDPSession() for Chromium-deep work.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cdp-compat": {
      "types": "./dist/cdp-compat.d.ts",
      "import": "./dist/cdp-compat.js"
    },
    "./oopif-attach": {
      "types": "./dist/oopif-attach.d.ts",
      "import": "./dist/oopif-attach.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "@ohmyperf/core": "workspace:*",
    "playwright": "catalog:"
  },
  "devDependencies": {
    "@ohmyperf/core": "workspace:*",
    "playwright": "catalog:",
    "vitest": "catalog:"
  }
}
